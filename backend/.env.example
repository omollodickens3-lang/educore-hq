# ── Server ──────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────
# Option A: Full connection string (Supabase / Railway)
DATABASE_URL=postgresql://user:password@host:5432/educore

# Option B: Individual fields (local PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=educore
DB_USER=postgres
DB_PASSWORD=yourpassword

# ── Authentication ────────────────────────────────
JWT_SECRET=replace_this_with_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── School details ────────────────────────────────
SCHOOL_NAME=Westside Primary & Junior School
SCHOOL_COUNTY=Nairobi County
SCHOOL_PHONE=0700000000
SCHOOL_EMAIL=info@westside.ac.ke
SCHOOL_PORTAL_URL=https://portal.westside.ac.ke

# ── Anthropic Claude API (content generation) ────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Africa's Talking SMS ──────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_africastalking_username
AT_SENDER_ID=EduCore

# ── Email (SendGrid) ─────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_key
FROM_EMAIL=noreply@westside.ac.ke
FROM_NAME=Westside School

# ── File uploads ─────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
